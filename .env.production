# Production Environment Variables for Forex Bot
# Замените значения ниже на ваши реальные токены и ключи

# Database Configuration
DATABASE_URL=postgresql://your_db_user:your_db_password@your_db_host:5432/your_db_name

# Redis Configuration  
REDIS_URL=redis://your_redis_host:6379/0

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_real_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_real_telegram_chat_id_here

# OpenAI Configuration
OPENAI_API_KEY=your_real_openai_api_key_here

# API Configuration
API_KEY=your_real_api_key_here

# Deployment Configuration
RENDER_EXTERNAL_HOSTNAME=your_app_name.onrender.com
WEBHOOK_MODE=true
WEBHOOK_URL=https://your_app_name.onrender.com/webhook

# Logging Configuration
LOG_LEVEL=INFO

# Scheduler Configuration
SCRAPER_SCHEDULE_HOUR=3
SCRAPER_SCHEDULE_MINUTE=0
TIMEZONE=Europe/Berlin

# Application Configuration
FLASK_PORT=10000
FLASK_HOST=0.0.0.0
FLASK_DEBUG=false

# Timezone Configuration
TZ=Europe/Berlin
