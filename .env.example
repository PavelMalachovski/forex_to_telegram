# Forex to Telegram Bot Configuration
# Copy this file to .env and fill in your actual values

# Required: Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
API_KEY=your_api_key_here

# Optional: OpenAI API for news analysis
OPENAI_API_KEY=your_openai_api_key_here

# Database Configuration (already configured for Render)
# DATABASE_URL is set automatically in production

# Multi-Source News Configuration
# Each source can be enabled/disabled and prioritized (lower number = higher priority)

# ForexFactory (Primary source - no API key required)
FOREX_FACTORY_ENABLED=true
FOREX_FACTORY_PRIORITY=1

# Alpha Vantage (Financial news and sentiment)
# Get free API key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_ENABLED=true
ALPHA_VANTAGE_PRIORITY=2
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Financial Modeling Prep (Economic calendar)
# Get free API key at: https://financialmodelingprep.com/developer/docs
FMP_ENABLED=true
FMP_PRIORITY=3
FMP_API_KEY=your_fmp_api_key_here

# NewsAPI (General financial news)
# Get free API key at: https://newsapi.org/register
NEWSAPI_ENABLED=true
NEWSAPI_PRIORITY=4
NEWSAPI_API_KEY=your_newsapi_api_key_here

# RSS Feeds (Always available, no API key required)
RSS_ENABLED=true
RSS_PRIORITY=5

# Render Configuration (for deployment)
RENDER_EXTERNAL_HOSTNAME=your_render_hostname
PORT=10000

# Notes:
# - ForexFactory is the primary source but may be blocked by Cloudflare
# - RSS feeds are always available as a fallback
# - API-based sources require registration but offer more reliable access
# - Priority determines the order sources are tried (1 = highest priority)
# - Disabled sources (enabled=false) will not be used
# - Sources without API keys will be automatically disabled
