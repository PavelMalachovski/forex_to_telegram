
# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Bot Mode: 'polling' for development, 'webhook' for production
BOT_MODE=polling

# Webhook Configuration (only needed for webhook mode)
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook
# OR for Render deployment:
RENDER_EXTERNAL_URL=https://your-app.onrender.com
# OR for local development with ngrok:
LOCAL_WEBHOOK_URL=https://your-ngrok-url.ngrok.io

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/forex_bot
# OR for development:
# DATABASE_URL=sqlite:///./forex_bot.db

# Logging Configuration
LOG_LEVEL=INFO
LOG_DIR=./logs

# Server Configuration (for webhook mode)
PORT=8000
HOST=0.0.0.0

# Development Settings
DEBUG=False
